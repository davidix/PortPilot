{
  "name": "portpilot",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm --filter @portpilot/shared build && pnpm -r --filter \"!./packages/shared\" build",
    "dev": "pnpm run build:shared && pnpm --parallel --filter @portpilot/agent --filter @portpilot/dashboard dev",
    "dev:all": "pnpm run build:shared && pnpm --parallel --filter @portpilot/agent --filter @portpilot/dashboard --filter @portpilot/extension dev",
    "build:shared": "pnpm --filter @portpilot/shared build",
    "dev:agent": "pnpm --filter @portpilot/agent dev",
    "dev:dashboard": "pnpm --filter @portpilot/dashboard dev",
    "dev:extension": "pnpm --filter @portpilot/extension dev",
    "typecheck": "pnpm -r typecheck"
  }
}
